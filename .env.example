# TakeNote target URL (defaults to the public demo)
BASE_URL=https://takenote.dev

# Required for the agent pipeline and CI failure analysis
ANTHROPIC_API_KEY=

# Optional: Slack webhook for CI notifications
SLACK_WEBHOOK_URL=

# Optional: GitHub token for CI PR comments (provided automatically by Actions)
GITHUB_TOKEN=

# Logger level: debug | info | warn | error
LOG_LEVEL=info
