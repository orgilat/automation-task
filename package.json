{
  "name": "takenote-qa-suite",
  "version": "1.0.0",
  "description": "End-to-end test suite for the TakeNote demo app built with Playwright and TypeScript.",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:headed": "playwright test --headed",
    "report": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report:serve": "allure serve allure-results",
    "test:full": "ts-node scripts/test-full.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
    "agents:bootstrap": "ts-node agents/bootstrapOrchestrator.ts",
    "agents:edit": "ts-node agents/editOrchestrator.ts",
    "agents:fix": "ts-node agents/fixOrchestrator.ts",
    "agents:clean": "ts-node agents/specialists/cleanCodeAgent.ts",
    "agents:github": "ts-node agents/specialists/githubAgent.ts",
    "ci:analyze-failures": "ts-node agents/specialists/failureAnalyzerAgent.ts",
    "docker": "make run"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "qa",
    "automation",
    "takenote"
  ],
  "author": "Or",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@axe-core/playwright": "^4.10.0",
    "allure-playwright": "^3.0.0",
    "docx": "^9.0.0",
    "dotenv": "^16.4.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "allure-commandline": "^2.31.0",
    "eslint": "^8.57.0",
    "eslint-plugin-playwright": "^2.1.0",
    "prettier": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
