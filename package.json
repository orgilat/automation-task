{
  "name": "takenote-qa-suite",
  "version": "1.0.0",
  "description": "End-to-end test suite for the TakeNote demo app, with an integrated multi-agent build pipeline.",
  "type": "commonjs",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:e2e": "playwright test tests/e2e",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:debug": "PWDEBUG=1 playwright test",
    "report": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report",
    "report:serve": "allure serve allure-results",
    "agents": "ts-node agents/index.ts",
    "agents:bootstrap": "ts-node agents/bootstrapOrchestrator.ts",
    "agents:edit": "ts-node agents/editOrchestrator.ts",
    "agents:fix": "ts-node agents/fixOrchestrator.ts",
    "agents:yaml": "ts-node agents/yamlOrchestrator.ts",
    "scrape": "ts-node agents/scraper/scrapeLocators.ts",
    "agents:clean": "ts-node agents/specialists/cleanCodeAgent.ts",
    "agents:github": "ts-node agents/specialists/githubAgent.ts",
    "agents:rollback": "ts-node agents/rollback.ts",
    "ci:analyze-failures": "ts-node agents/specialists/failureAnalyzerAgent.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "clean:tests": "ts-node -e \"const {runCleanCodeAgent} = require('./agents/specialists/cleanCode'); runCleanCodeAgent(['tests/e2e/notes/notes.spec.ts','tests/e2e/notes/context-menu.spec.ts','tests/e2e/categories/categories.spec.ts','tests/e2e/search/search.spec.ts','tests/e2e/favorites/favorites.spec.ts','tests/e2e/trash/trash.spec.ts','tests/e2e/persistence/persistence.spec.ts','tests/e2e/settings/settings.spec.ts']).then(console.log)\"",
    "format": "prettier --write \"**/*.{ts,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,json,md,yml,yaml}\"",
    "docker": "make run"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "qa",
    "automation",
    "takenote"
  ],
  "author": "Or",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@axe-core/playwright": "^4.10.0",
    "allure-playwright": "^3.0.0",
    "docx": "^9.0.0",
    "dotenv": "^16.4.0",
    "glob": "^11.0.0",
    "js-yaml": "^4.1.0",
    "winston": "^3.15.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "allure-commandline": "^2.31.0",
    "eslint": "^8.57.0",
    "eslint-plugin-playwright": "^2.1.0",
    "prettier": "^3.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  }
}
